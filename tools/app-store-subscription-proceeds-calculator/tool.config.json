{
  "slug": "app-store-subscription-proceeds-calculator",
  "title": "App Store Subscription Proceeds Calculator",
  "titleKo": "앱스토어 구독 실수령액 계산기",
  "description": "Estimate App Store subscription payout from mixed 70% and 85% proceeds buckets across monthly and annual billings, then compare take-home after VAT, refunds, service cost, and fixed monthly spend.",
  "headline": "📱 App Store Subscription Proceeds Calculator | 앱스토어 구독 실수령액 계산기",
  "subheadline": "Model 70% vs 85% App Store proceeds across monthly and annual subscription billings, then see payout, blended proceeds rate, and take-home after VAT, refunds, support cost, and fixed spend.",
  "currencyCode": "USD",
  "inputs": [
    {
      "id": "monthly70",
      "label": "Monthly subscribers billed at 70% proceeds",
      "type": "number",
      "value": 180,
      "min": 0,
      "step": 1
    },
    {
      "id": "monthly85",
      "label": "Monthly subscribers billed at 85% proceeds",
      "type": "number",
      "value": 120,
      "min": 0,
      "step": 1
    },
    {
      "id": "monthlyPrice",
      "label": "Monthly subscription price (VAT-inclusive, USD)",
      "type": "number",
      "value": 9.99,
      "min": 0.01,
      "step": 0.01
    },
    {
      "id": "annual70",
      "label": "Annual subscribers billed this month at 70% proceeds",
      "type": "number",
      "value": 18,
      "min": 0,
      "step": 1
    },
    {
      "id": "annual85",
      "label": "Annual subscribers billed this month at 85% proceeds",
      "type": "number",
      "value": 12,
      "min": 0,
      "step": 1
    },
    {
      "id": "annualPrice",
      "label": "Annual subscription price (VAT-inclusive, USD)",
      "type": "number",
      "value": 79.99,
      "min": 0.01,
      "step": 0.01
    },
    {
      "id": "vatRate",
      "label": "VAT / GST rate (%)",
      "type": "number",
      "value": 10,
      "min": 0,
      "max": 100,
      "step": 0.1
    },
    {
      "id": "refundRate",
      "label": "Refund rate (%)",
      "type": "number",
      "value": 3,
      "min": 0,
      "max": 100,
      "step": 0.1
    },
    {
      "id": "activeSubscribers",
      "label": "Active subscribers to support this month",
      "type": "number",
      "value": 330,
      "min": 0,
      "step": 1
    },
    {
      "id": "costPerActiveSubscriber",
      "label": "Monthly service cost per active subscriber (USD)",
      "type": "number",
      "value": 1.4,
      "min": 0,
      "step": 0.01
    },
    {
      "id": "fixedMonthlyCosts",
      "label": "Fixed monthly costs (USD)",
      "type": "number",
      "value": 1800,
      "min": 0,
      "step": 0.01
    }
  ],
  "formula": {
    "monthlyGross": "(monthly70 + monthly85) * monthlyPrice",
    "annualGross": "(annual70 + annual85) * annualPrice",
    "grossBillings": "monthlyGross + annualGross",
    "netBillingsExVat": "grossBillings / (1 + vatRate / 100)",
    "netBillingsAfterRefunds": "netBillingsExVat * (1 - refundRate / 100)",
    "gross70": "(monthly70 * monthlyPrice) + (annual70 * annualPrice)",
    "gross85": "(monthly85 * monthlyPrice) + (annual85 * annualPrice)",
    "payout70": "(gross70 / (1 + vatRate / 100)) * (1 - refundRate / 100) * 0.70",
    "payout85": "(gross85 / (1 + vatRate / 100)) * (1 - refundRate / 100) * 0.85",
    "appStorePayout": "payout70 + payout85",
    "blendedProceedsRate": "netBillingsAfterRefunds > 0 ? (appStorePayout / netBillingsAfterRefunds) * 100 : 0",
    "serviceCost": "activeSubscribers * costPerActiveSubscriber",
    "netTakeHome": "appStorePayout - serviceCost - fixedMonthlyCosts",
    "all70BaselinePayout": "netBillingsAfterRefunds * 0.70",
    "proceedsUpliftVsAll70": "appStorePayout - all70BaselinePayout",
    "payoutRatioOnGross": "grossBillings > 0 ? appStorePayout / grossBillings : 0",
    "breakEvenGrossBillings": "payoutRatioOnGross > 0 ? (serviceCost + fixedMonthlyCosts) / payoutRatioOnGross : 0"
  },
  "summaryLines": [
    {
      "label": "Gross customer billings",
      "expr": "grossBillings",
      "format": "currency"
    },
    {
      "label": "Net billings ex. VAT/refunds",
      "expr": "netBillingsAfterRefunds",
      "format": "currency"
    },
    {
      "label": "App Store payout",
      "expr": "appStorePayout",
      "format": "currency"
    },
    {
      "label": "Blended proceeds rate",
      "expr": "blendedProceedsRate",
      "format": "percent"
    },
    {
      "label": "85% bucket uplift vs all-70%",
      "expr": "proceedsUpliftVsAll70",
      "format": "currency"
    },
    {
      "label": "Net take-home after costs",
      "expr": "netTakeHome",
      "format": "currency"
    },
    {
      "label": "Break-even gross billings",
      "expr": "breakEvenGrossBillings",
      "format": "currency"
    }
  ],
  "faq": [
    {
      "q": "What does the 70% vs 85% proceeds split mean?",
      "a": "Use the 70% bucket for standard App Store proceeds and the 85% bucket for subscriptions or programs that qualify for reduced commission economics in your current reporting month."
    },
    {
      "q": "Should annual subscribers be total active annual subscribers?",
      "a": "No. Enter annual subscriptions that were actually billed this month so the payout estimate matches monthly cash collection more closely."
    },
    {
      "q": "Does this include VAT, GST, and refunds?",
      "a": "Yes. The calculator removes VAT or GST first, then applies the refund rate before calculating App Store payout and take-home."
    }
  ]
}
